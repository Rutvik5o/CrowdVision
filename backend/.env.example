# ── Backend Environment Variables ───────────────────────────
# Set these in Railway dashboard under Variables tab

# Port (Railway sets this automatically)
PORT=8000

# Your own deployed backend URL (used to build download links in responses)
BACKEND_URL=https://your-app-name.railway.app

# Where to store output files (Railway ephemeral disk)
OUTPUT_DIR=/tmp/crowdvision_output
